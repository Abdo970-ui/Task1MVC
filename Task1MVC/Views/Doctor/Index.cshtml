@foreach (var doctor in Model)
{
    <div class="col-md-4 mb-4">
        <div class="card shadow h-100 text-center">

            <img src="~/images/@doctor.ImagePng"
                 class="card-img-top"
                 style="height:220px; object-fit:cover;"
                 alt="Doctor Image" />

            <div class="card-body">
                <h5 class="card-title">@doctor.Name</h5>

                <span class="badge bg-primary mb-3">
                    @doctor.Specialization
                </span>

                <div class="d-grid">
                    <a href="/Appointment/Create?doctorId=@doctor.Id"
                       class="btn btn-success">
                        Book Appointment
                    </a>
                </div>
            </div>
        </div>
    </div>
}
<div class="d-flex justify-content-center mt-4">

    <nav>
        <ul class="pagination">

            <!-- Previous -->
            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="/Doctor?page=@(ViewBag.CurrentPage - 1)&searchName=@Context.Request.Query["searchName"]&specialization=@Context.Request.Query["specialization"]">
                        Previous
                    </a>
                </li>
            }

            <!-- Page Numbers -->
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link"
                       href="/Doctor?page=@i&searchName=@Context.Request.Query["searchName"]&specialization=@Context.Request.Query["specialization"]">
                        @i
                    </a>
                </li>
            }

            <!-- Next -->
            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="/Doctor?page=@(ViewBag.CurrentPage + 1)&searchName=@Context.Request.Query["searchName"]&specialization=@Context.Request.Query["specialization"]">
                        Next
                    </a>
                </li>
            }

        </ul>
    </nav>

</div>